{
  "name": "stream-screen",
  "private": true,
  "version": "0.1.0",
  "description": "StreamScreen — self-hosted, LAN-first, always-free, unlimited-time peer-to-peer remote desktop for Windows over WebRTC.",
  "workspaces": [
    "packages/*",
    "e2e"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "test": "npm run test --workspaces --if-present",
    "dev:signaling": "npm -w @stream-screen/signaling run dev",
    "e2e": "npm -w @stream-screen/e2e test"
  },
  "devDependencies": {
    "typescript": "^5.5",
    "vitest": "^2",
    "@types/node": "^20"
  }
}

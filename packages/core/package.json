{
  "name": "@stream-screen/core",
  "version": "0.1.0",
  "type": "module",
  "description": "StreamScreen shared protocol types, WebRTC peer wrapper, adaptive engine, and input codec. Pure TypeScript — runs in browser and node, no native deps.",
  "license": "MIT",
  "author": "divyamohan1993 <divyamohan1993@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/divyamohan1993/stream-screen.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.12",
    "vitest": "^4.1.9"
  }
}
